// Healer Movement Configuration
//
// All scorer weights, radii, thresholds, and commitment windows for the
// healer posture state machine (FREE/PRESSURED/ESCAPE/DIP). Loaded
// identically in headless and graphical modes by MovementConfigPlugin
// (src/states/play_match/movement_config.rs); the plugin panics at startup
// if this file is missing, malformed, or fails validation.
//
// Missing fields fall back to the struct defaults in movement_config.rs —
// every field is stated explicitly here anyway so this file is the single
// place balance tuning happens.
//
// Scorer term weights are all additive interest terms. Hard constraints
// (boundary, ally-anchor) are boolean masks in the scorer, not weights — the
// old ally_anchor/boundary_penalty penalty knobs and their dominance invariant
// were retired with the context-steering mask refactor.
(
    shared: (
        // PRESSURED proximity condition: a targeting enemy within this
        // radius (or melee/pet, or closing) flips the posture.
        danger_radius: 12.0,
        // Intent bound on the melee/pet/closing trigger branch: such a
        // threat counts only within this radius (a melee targeting the
        // healer from across the arena is not yet pressure).
        threat_intent_radius: 30.0,
        // Stay within heal range of the anchor ally while PRESSURED.
        heal_range: 40.0,
        // FREE formation point: offset behind the engaged-ally centroid.
        formation_offset: 8.0,
        // FREE formation point: bias toward arena center (0..1).
        center_bias: 0.3,
        // Committed-direction window in seconds (anti-zigzag; plan band
        // 0.4-0.8).
        commit_window: 0.6,
        // Hysteresis: minimum seconds PRESSURED holds after entry before it
        // may relax back to FREE (threat hovering at the radius must not
        // strobe the posture).
        pressured_hold: 1.5,
        // MovementDirective TTL in seconds (expires = now + ttl).
        directive_ttl: 1.0,
        // ESCAPE windows shorter than this are ignored.
        escape_min_window: 0.5,
        // Defer non-critical casts during ESCAPE/DIP unless an ally is
        // below this HP fraction.
        urgency_hp_threshold: 0.5,
        // Anchor ally switches require this HP-fraction injury margin.
        anchor_switch_margin: 0.1,
        // Wand-range pull target distance (Priest wand range).
        wand_range: 30.0,
    ),
    priest: (
        weights: (
            threat_repulsion: 3.0,
            formation_pull: 2.0,
            corner_penalty: 6.0,
            wand_pull: 0.5,
            commitment_bonus: 1.5,
        ),
        // FREE-directive tuning (formerly hardcoded consts in priest.rs).
        formation_shift_threshold: 3.0, // re-target the formation point past this XZ move
        formation_deadzone: 1.5,        // no Point directive issued within this of the point
        directive_refresh_margin: 0.25, // refresh the standing walk below this remaining TTL
        dip_budget: 6.0,                // Psychic Scream dip walk-stun-return budget (U4)
        healing_heavy_hp: 0.6,          // defer the offensive dip below this team HP fraction (U4)
    ),
    paladin: (
        weights: (
            threat_repulsion: 3.0,
            formation_pull: 0.0,      // Paladin keeps melee identity — no backline point
            corner_penalty: 4.0,
            wand_pull: 0.0,           // Paladin has no wand
            commitment_bonus: 1.5,
        ),
        // PRESSURED retreat range (instead of face-tanking at melee).
        fallback_range: 15.0,
        // DIP walk-stun-return duration budget in seconds.
        dip_budget: 6.0,
        // Healing-heavy PRESSURED trigger: lowest team HP fraction
        // (self included, pets excluded) below this pulls the Paladin to
        // fallback range even before it is focused.
        healing_heavy_hp: 0.6,
    ),
    // Melee target-swap (bucket A offensive-punish): swap off a kited kill
    // target onto a softer in-melee enemy instead of chasing forever.
    melee: (
        swap_range: 4.0,       // softer target must be this close (yards) to swap to
        swap_hysteresis: 2.0,  // min seconds between swaps (anti-ping-pong)
        swap_hp_margin: 0.15,  // softer target must be this HP fraction below the kill target
    ),
    // Mage ENGAGE/KITE pilot (Part B). Kiting orbits the kill target between
    // range_band_min and range_band_max while repelling melee threats.
    mage: (
        weights: (
            threat_repulsion: 3.0,
            formation_pull: 0.0,   // Mage has no backline formation point
            corner_penalty: 4.0,
            wand_pull: 0.0,        // Mage has no wand
            range_band: 2.0,       // ring attraction toward the kill target
            commitment_bonus: 1.5,
        ),
        range_band_min: 8.0,       // SAFE_KITING_DISTANCE — stay out of melee of the kill target
        range_band_max: 30.0,      // within AUTO_SHOT_RANGE — keep the kill target in cast range
        kite_hold: 1.0,            // hysteresis floor against KITE<->ENGAGE strobing
        directive_ttl: 3.0,        // covers a Frostbolt cast so movement survives the cast
        commit_window: 0.6,        // anti-zigzag committed-direction window
        kite_entry_radius: 20.0,   // (unused: Mage is aura-gated)
        kite_sustain_radius: 24.0, // (unused: Mage is aura-gated)
    ),
    // Hunter ENGAGE/KITE (proximity-gated): kites an un-rooted melee, so unlike
    // the Mage's orbit it must be FLEE-DOMINANT — strong threat_repulsion drives
    // the escape, and a weak range_band with a near-shot-range max only bends
    // the flee to keep the target shootable (matching the legacy "flee unless
    // leaving shot range"). Stays out of the 8yd dead zone.
    hunter: (
        weights: (
            threat_repulsion: 1.0,  // minor; flee does the heavy lifting
            formation_pull: 0.0,
            corner_penalty: 8.0,    // MUST exceed flee — bends escapes out of corners (corner-stuck fix)
            wand_pull: 0.0,
            range_band: 0.5,        // gentle keep-in-range, not an orbit
            flee: 6.0,              // distance-max flee from the nearest chaser (the kiter's core)
            commitment_bonus: 1.5,
        ),
        range_band_min: 8.0,       // HUNTER_DEAD_ZONE — can't shoot inside this
        range_band_max: 34.0,      // ~AUTO_SHOT_RANGE — only pull in near the shot-range edge
        kite_hold: 1.0,
        directive_ttl: 3.0,        // covers an Aimed Shot cast
        commit_window: 0.6,
        kite_entry_radius: 20.0,   // closing-range band — a melee within this opens KITE
        kite_sustain_radius: 24.0, // hold KITE a touch past entry (anti-strobe)
    ),
)
